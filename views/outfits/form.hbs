{{>navbar}}

<main class="p-4 pt-20 pb-24 sm:max-w-lg sm:mx-auto">
  <div class="flex items-center gap-3 mb-6">
    <a
      href="{{returnTo}}"
      class="btn btn-ghost btn-sm btn-circle"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
        stroke-width="2"
        stroke="currentColor"
        class="size-4"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18"
        />
      </svg>
    </a>
    <h1 class="text-2xl font-bold">
      {{#if outfit}}{{t 'lang.EDIT_OUTFIT'}}{{else}}{{t
      'lang.BUILD_OUTFIT_TITLE'}}{{/if}}
    </h1>
  </div>

  {{#if categoryRows.length}}
  <form
    method="POST"
    action="{{#if outfit}}/outfits/{{outfit.id}}{{else}}/outfits{{/if}}"
    class="flex flex-col gap-4"
  >
    <input type="hidden" name="returnTo" value="{{returnTo}}" />
    {{#if returnToWeek}}<input type="hidden" name="returnToWeek" value="{{returnToWeek}}" />{{/if}}
    <div class="card bg-base-100 shadow-sm mb-4">
      <div
        id="outfit-rows-list"
        class="card-body p-3 divide-y divide-base-300"
        _="init js(me) Sortable.create(me, { handle: '.drag-handle', animation: 150, ghostClass: 'opacity-40' }) end"
      >
        {{#each categoryRows}}{{> outfit_row row=this}}{{/each}}
      </div>
      <div class="flex gap-2 p-3 pt-0">
        <input
          type="text"
          id="add-row-input"
          list="add-row-suggestions"
          class="input input-bordered input-sm flex-1"
          placeholder="{{t 'lang.TYPE_OR_SELECT_CATEGORY'}}"
          autocomplete="off"
        />
        <datalist id="add-row-suggestions">
          {{#each allCategoryRows}}
          <option value="{{this.value}}"></option>
          {{/each}}
        </datalist>
        <button
          type="button"
          class="btn btn-sm btn-outline"
          _="on click
             set cat to the value of #add-row-input
             if cat is not ''
               js(cat) htmx.ajax('GET', '/outfits/row-fragment?category=' + encodeURIComponent(cat), {target: '#outfit-rows-list', swap: 'beforeend'}) end
               set the value of #add-row-input to ''
             end"
        >
          {{t 'lang.ADD_ROW'}}
        </button>
      </div>
    </div>

    <div class="form-control">
      <label class="label"
        ><span class="label-text">{{t 'lang.NAME'}}</span></label
      >
      <input
        type="text"
        name="name"
        class="input input-bordered w-full"
        value="{{#if outfit}}{{outfit.name}}{{/if}}"
        placeholder="e.g. Summer Date Night"
        required
      />
    </div>

    <div class="form-control">
      <label class="label"
        ><span class="label-text">{{t 'lang.NOTES'}}</span></label
      >
      <textarea
        name="notes"
        class="textarea textarea-bordered w-full"
        rows="2"
        placeholder="Occasion, weather, etc."
      >
{{#if outfit}}{{outfit.notes}}{{/if}}</textarea
      >
    </div>

    <div class="form-control">
      <label class="label">
        <span class="label-text">
          {{t 'lang.ADD_TO_CALENDAR'}}
        </span>
      </label>
      <input
        type="date"
        name="scheduleDate"
        class="input input-bordered w-full"
        {{#if scheduleDate}}value="{{scheduleDate}}"{{/if}}
      />
    </div>

    <div class="flex gap-2 mt-2">
      <button type="submit" class="btn btn-primary flex-1">
        {{t 'lang.SAVE'}}
      </button>
      {{#unless outfit}}
      <a href="/outfits/new" class="btn btn-ghost">{{t 'lang.START_OVER'}}</a>
      {{/unless}}
      <a
        href="{{returnTo}}"
        class="btn btn-ghost"
        >{{t 'lang.CANCEL'}}</a
      >
    </div>
  </form>

  {{else}}
  <div
    class="flex flex-col items-center justify-center gap-4 pt-20 text-base-content/40"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      fill="none"
      viewBox="0 0 24 24"
      stroke-width="1"
      stroke="currentColor"
      class="size-16"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        d="M9 3.75H6.912a2.25 2.25 0 0 0-2.15 1.588L2.35 13.177a2.25 2.25 0 0 0-.1.661V18a2.25 2.25 0 0 0 2.25 2.25h15A2.25 2.25 0 0 0 21.75 18v-4.162c0-.224-.034-.447-.1-.661L19.24 5.338a2.25 2.25 0 0 0-2.15-1.588H15M2.25 13.5h3.86a2.251 2.251 0 0 1 2.012 1.244l.256.512a2.251 2.251 0 0 0 2.013 1.244h3.218a2.251 2.251 0 0 0 2.013-1.244l.256-.512a2.251 2.251 0 0 1 2.013-1.244h3.859M12 3v8.25m0 0-3-3m3 3 3-3"
      />
    </svg>
    <p class="text-center text-sm px-4">{{t 'lang.NO_GARMENTS_FOR_BUILDER'}}</p>
    <a href="/wardrobe/new" class="btn btn-primary btn-sm"
      >{{t 'lang.NEW_GARMENT'}}</a
    >
  </div>
  {{/if}}
</main>

{{>garmentModal}} {{>dock}}
